{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helpshift.com/kb/schemas/manifest.schema.json",
  "title": "KB Project Manifest",
  "description": "Per-project .meta/manifest.json tracking source hashes, KB doc hashes, template/schema hashes, and generator metadata.",
  "type": "object",
  "required": ["project", "generated_at", "generator", "schema_versions", "sources", "kb_docs"],
  "properties": {
    "project": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "last_updated": { "type": "string", "format": "date-time" },
    "last_mode": {
      "type": "string",
      "enum": ["full", "incremental", "refresh-stale"]
    },
    "last_full_regeneration": { "type": "string", "format": "date-time" },
    "generator": {
      "type": "object",
      "required": ["kb_engineer_version"],
      "properties": {
        "kb_engineer_version": { "type": "string" },
        "skill_versions": {
          "type": "object",
          "patternProperties": {
            "^kb-(identity|generation|query)$": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "schema_versions": {
      "type": "object",
      "properties": {
        "frontmatter": { "type": "string" },
        "graph": { "type": "string" },
        "manifest": { "type": "string" }
      },
      "additionalProperties": true
    },
    "template_hashes": {
      "type": "object",
      "description": "SHA-256 (hex) or 'inline-default'. Used for drift detection on incremental runs.",
      "patternProperties": {
        "^(module|service|datastore|consumer|project|architecture|dependencies|home)$": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "description": "Tracked source files that contribute to one or more KB docs.",
      "items": {
        "type": "object",
        "required": ["path", "hash", "contributes_to"],
        "properties": {
          "path": { "type": "string" },
          "hash": { "type": "string" },
          "size_bytes": { "type": "integer" },
          "contributes_to": {
            "type": "array",
            "items": { "type": "string" }
          },
          "last_modified": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "kb_docs": {
      "type": "array",
      "description": "KB documents this project owns (relative to the project's KB folder).",
      "items": {
        "type": "object",
        "required": ["path", "hash"],
        "properties": {
          "path": { "type": "string" },
          "hash": { "type": "string" },
          "size_bytes": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["hub", "architecture", "dependencies", "module", "service", "consumer", "datastore", "index"]
          },
          "generated_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
