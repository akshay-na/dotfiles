{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "project", "generated_at", "files"],
  "properties": {
    "version": { "const": 1 },
    "project": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["sha256", "last_analyzed"],
        "properties": {
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "last_analyzed": { "type": "string", "format": "date-time" },
          "contributed_to": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
