#!/bin/sh
# cursor-memory-hook - Flags memory refresh after git operations
# Symlink to .git/hooks/post-merge and .git/hooks/post-checkout

set -e

MEMORY_ROOT="$HOME/.cursor/memory"

# Derive project name from git remote or folder
get_project_name() {
    # Try git remote first
    remote_url=$(git remote get-url origin 2>/dev/null || true)
    if [ -n "$remote_url" ]; then
        # Extract repo name from URL, remove .git suffix, lowercase
        echo "$remote_url" | sed 's/.*\///' | sed 's/\.git$//' | tr '[:upper:]' '[:lower:]'
    else
        # Fallback to repo root folder name
        basename "$(git rev-parse --show-toplevel 2>/dev/null)" | tr '[:upper:]' '[:lower:]'
    fi
}

# Get changed files between HEAD@{1} and HEAD
get_changed_files() {
    git diff --name-only HEAD@{1} HEAD 2>/dev/null || true
}

main() {
    # Must be in a git repo
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        exit 0
    fi

    # Only run on master/main branch
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)
    case "$current_branch" in
        main|master) ;;
        *) exit 0 ;;
    esac

    project_name=$(get_project_name)
    if [ -z "$project_name" ]; then
        exit 0
    fi

    changed_files=$(get_changed_files)
    if [ -z "$changed_files" ]; then
        exit 0
    fi

    project_memory_dir="$MEMORY_ROOT/projects/$project_name"
    pending_file="$project_memory_dir/_pending_refresh.md"

    # Create project memory directory if needed
    mkdir -p "$project_memory_dir"

    # Generate timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Determine trigger type from hook name
    hook_name=$(basename "$0")
    case "$hook_name" in
        post-merge) trigger="post-merge" ;;
        post-checkout) trigger="post-checkout" ;;
        *) trigger="manual" ;;
    esac

    # Write or append to pending refresh file
    if [ -f "$pending_file" ]; then
        # Append to existing file
        echo "" >> "$pending_file"
        echo "## Additional changes ($trigger at $timestamp)" >> "$pending_file"
        echo "" >> "$pending_file"
        echo "$changed_files" | while read -r file; do
            [ -n "$file" ] && echo "- $file" >> "$pending_file"
        done
    else
        # Create new file
        cat > "$pending_file" << EOF
---
trigger: $trigger
timestamp: $timestamp
---

# Pending Knowledge Refresh

Files changed since last knowledge sync:

EOF
        echo "$changed_files" | while read -r file; do
            [ -n "$file" ] && echo "- $file" >> "$pending_file"
        done
        echo "" >> "$pending_file"
        echo "Review and update memory entries as needed." >> "$pending_file"
    fi
}

main "$@"
