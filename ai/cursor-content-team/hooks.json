{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "./hooks/cursor-zone-writes.sh",
        "matcher": "Write|Edit|StrReplace|MultiEdit|Delete",
        "failClosed": false,
        "timeout": 5
      },
      {
        "command": "./hooks/subagent-task-antidup-preflight.sh",
        "matcher": "Task",
        "failClosed": true,
        "enabled": true,
        "timeout": 5
      },
      {
        "command": "./hooks/subagent-protocol-inject.sh",
        "matcher": "Task",
        "failClosed": false,
        "enabled": true,
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./hooks/safe-shell.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "postToolUse": []
  }
}
