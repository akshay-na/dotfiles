{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/telemetry-session-start.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "sessionEnd": [
      {
        "command": "./hooks/telemetry-session-end.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "./hooks/cursor-zone-writes.sh",
        "matcher": "Write|Edit|StrReplace|MultiEdit|Delete",
        "failClosed": false,
        "timeout": 5
      },
      {
        "command": "./hooks/subagent-task-antidup-preflight.sh",
        "matcher": "Task",
        "failClosed": true,
        "enabled": true,
        "timeout": 5
      },
      {
        "command": "./hooks/subagent-protocol-inject.sh",
        "matcher": "Task",
        "failClosed": false,
        "enabled": true,
        "timeout": 5
      },
      {
        "command": "./hooks/telemetry-pre-tool.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "command": "./hooks/telemetry-post-tool.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "postToolUseFailure": [
      {
        "command": "./hooks/telemetry-post-tool-failure.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./hooks/safe-shell.sh",
        "failClosed": false,
        "timeout": 5
      },
      {
        "command": "./hooks/telemetry-shell-before.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "afterShellExecution": [
      {
        "command": "./hooks/telemetry-shell-after.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "./hooks/telemetry-mcp-before.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "afterMCPExecution": [
      {
        "command": "./hooks/telemetry-mcp-after.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "subagentStart": [
      {
        "command": "./hooks/telemetry-subagent-start.sh",
        "failClosed": false,
        "timeout": 5
      }
    ],
    "subagentStop": [
      {
        "command": "./hooks/telemetry-subagent-stop.sh",
        "failClosed": false,
        "timeout": 5
      }
    ]
  }
}
