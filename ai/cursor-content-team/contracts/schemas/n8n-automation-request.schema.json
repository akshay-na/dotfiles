{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-org://contracts/schemas/n8n-automation-request.schema.json",
  "title": "n8n / HTTP automation payload → content org",
  "description": "Typical JSON body for headless runs (e.g. n8n HTTP Request). workspace_root is the content corpus git root.",
  "type": "object",
  "additionalProperties": true,
  "required": ["workspace_root", "brief", "task_id"],
  "properties": {
    "workspace_root": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to content repo; plans go to {workspace_root}/.cursor/docs/plans/"
    },
    "brief": { "type": "string" },
    "task_id": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string" },
    "post_id": {
      "type": "string",
      "description": "Stable post identifier propagated across correction runs."
    },
    "post_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Current post artifact version."
    },
    "parent_post_id": {
      "type": ["string", "null"]
    },
    "channel": {
      "type": "string",
      "enum": ["linkedin", "instagram", "twitter_x"]
    },
    "content_type": {
      "type": "string"
    },
    "workflow": {
      "type": "string",
      "description": "Workflow identifier/name for artifact run metadata."
    },
    "correction_of": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "target_schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Requested output schema version for artifact emission."
    },
    "media_discovery_mode": {
      "type": "string",
      "enum": ["parallel", "post_approval", "disabled"]
    },
    "correction_enqueue_mode": {
      "type": "string",
      "enum": ["execute_workflow", "webhook", "vault_queue", "manual"]
    },
    "execution_mode": {
      "type": "string",
      "enum": ["automation", "interactive"],
      "default": "automation"
    },
    "correction_brief": { "type": "string" },
    "target_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "git_branch": { "type": "string" },
    "git_remote": { "type": "string" },
    "pull_before": { "type": "boolean", "default": true },
    "push_after_commit": { "type": "boolean", "default": true },
    "commit_template_path": {
      "type": "string",
      "default": "~/.gitmessage"
    },
    "create_branch": { "type": "string" },
    "_marker": {
      "type": "string",
      "description": "Optional; pass through to subagent envelope for correlation."
    },
    "json_output": {
      "type": "boolean",
      "default": true,
      "description": "When true (default), main org agents emit final reply as JSON per main-agent-response.schema.json. Set false for plain prose."
    }
  }
}
