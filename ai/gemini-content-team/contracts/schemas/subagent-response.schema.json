{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-org://contracts/schemas/subagent-response.schema.json",
  "title": "Content org subagent response envelope (headless JSON)",
  "description": "Subagent reply (Task tool or headless). Single JSON object only. Total serialized size should not exceed 8192 bytes.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "contract", "_marker", "status", "agent", "summary", "next_actions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "contract": {
      "type": "string",
      "const": "subagent-response-v1"
    },
    "_marker": {
      "type": "string",
      "minLength": 1,
      "description": "UUID from parent/hook; must match session marker exactly."
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warn", "blocked", "error", "malformed"]
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "maxLength": 120,
      "description": "caveman-ultra unless security-autoclarity applies."
    },
    "artifacts": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string" }
    },
    "findings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["severity", "category", "note"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "med", "high", "critical"]
          },
          "category": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "note": { "type": "string", "maxLength": 400 },
          "fix": { "type": "string" },
          "reported_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "token_stats": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "out_words_est": { "type": "integer" },
        "tool_calls": { "type": "integer" }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "memory_writes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "degraded_reason": {
      "type": "string",
      "description": "Non-empty when status is malformed or suspected secret leak."
    },
    "reported_by": {
      "type": "array",
      "description": "Ordered agent ids from origin to root (D12).",
      "items": { "type": "string" }
    }
  }
}
