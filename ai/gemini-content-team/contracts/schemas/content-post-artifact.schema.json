{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-org://contracts/schemas/content-post-artifact.schema.json",
  "title": "Content post artifact for n8n automation",
  "description": "Canonical content-team output consumed by n8n social automation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract",
    "agent",
    "status",
    "run",
    "post",
    "content",
    "approval",
    "obsidian",
    "media",
    "paths",
    "channel_constraints",
    "compat",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "contract": {
      "type": "string",
      "const": "content-post-artifact-v1"
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warn", "error"]
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "post": {
      "$ref": "#/$defs/post"
    },
    "content": {
      "$ref": "#/$defs/content"
    },
    "approval": {
      "$ref": "#/$defs/approval"
    },
    "obsidian": {
      "$ref": "#/$defs/obsidian"
    },
    "media": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/media"
      }
    },
    "paths": {
      "$ref": "#/$defs/paths"
    },
    "channel_constraints": {
      "$ref": "#/$defs/channel_constraints"
    },
    "compat": {
      "$ref": "#/$defs/compat"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "path": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "channel": {
      "type": "string",
      "enum": ["linkedin", "instagram", "twitter_x"]
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "idempotency_key",
        "workflow",
        "execution_mode",
        "execution_id",
        "parent_execution_id"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "idempotency_key": { "type": "string", "minLength": 1 },
        "workflow": { "type": "string", "minLength": 1 },
        "execution_mode": { "type": "string", "enum": ["automation", "interactive"] },
        "execution_id": { "type": ["string", "null"] },
        "parent_execution_id": { "type": ["string", "null"] }
      }
    },
    "post": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "post_id",
        "version",
        "parent_post_id",
        "correction_of",
        "channel",
        "content_type",
        "status",
        "title",
        "slug"
      ],
      "properties": {
        "post_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "parent_post_id": {
          "type": ["string", "null"]
        },
        "correction_of": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "channel": {
          "$ref": "#/$defs/channel"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "approved", "rejected", "published", "error"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "slug": {
          "type": ["string", "null"]
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "format", "summary", "draft_path", "extensions"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "format": {
          "type": "string",
          "enum": ["plain_text", "markdown"]
        },
        "summary": {
          "type": ["string", "null"]
        },
        "draft_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "linkedin": {
              "type": "object",
              "additionalProperties": true
            },
            "instagram": {
              "type": "object",
              "additionalProperties": true
            },
            "twitter_x": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "state", "feedback", "reviewed_at"],
      "properties": {
        "required": { "type": "boolean" },
        "state": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "expired"]
        },
        "feedback": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "obsidian": {
      "type": "object",
      "additionalProperties": false,
      "required": ["note_rel", "attachment_glob", "frontmatter_keys"],
      "properties": {
        "note_rel": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "attachment_glob": { "type": "string", "minLength": 1 },
        "frontmatter_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "type",
        "mime_type",
        "path",
        "file_name",
        "alt_text",
        "sha256",
        "bytes",
        "status",
        "drive_file_id"
      ],
      "properties": {
        "asset_id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["image", "video"] },
        "mime_type": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "file_name": { "type": "string", "minLength": 1 },
        "alt_text": { "type": ["string", "null"] },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": ["generated", "discovered", "uploaded", "missing", "error"]
        },
        "drive_file_id": { "type": ["string", "null"] }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_root",
        "manifest_path",
        "audit_log_path",
        "draft_path",
        "staging_dir",
        "archive_dir"
      ],
      "properties": {
        "workspace_root": {
          "type": "string",
          "const": "/home/n8n-runner/content-foundry"
        },
        "manifest_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "audit_log_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "draft_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "staging_dir": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        },
        "archive_dir": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\.\\.)[^\\0]+$"
        }
      }
    },
    "channel_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_text_chars", "required_media", "allowed_media_types"],
      "properties": {
        "max_text_chars": {
          "type": "integer",
          "minimum": 1
        },
        "required_media": { "type": "boolean" },
        "allowed_media_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["image", "video"]
          }
        }
      }
    },
    "compat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "legacy_article_id",
        "legacy_media_paths",
        "channel_assumed"
      ],
      "properties": {
        "legacy_article_id": {
          "type": ["string", "null"]
        },
        "legacy_media_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "channel_assumed": { "type": "boolean" }
      }
    }
  }
}
