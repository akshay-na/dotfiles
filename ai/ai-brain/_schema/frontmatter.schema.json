{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dotmate.local/ai-brain/frontmatter.schema.json",
  "title": "Unified ai-brain node frontmatter",
  "type": "object",
  "required": ["title", "type", "generated_at"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": [
        "decision",
        "constraint",
        "principle",
        "risk",
        "retrospection",
        "todo",
        "overview",
        "architecture",
        "dependency",
        "module",
        "service",
        "datastore"
      ]
    },
    "project": { "type": "string", "description": "Set for project-scoped KB nodes." },
    "tags": { "type": "array", "items": { "type": "string" } },
    "generated_at": { "type": "string", "format": "date-time" },
    "generated_by": {
      "type": "string",
      "description": "Agent id or touch-writer token (distributed model)."
    },
    "category": { "type": "string", "description": "Memory-style category when overlapping memory layout." },
    "status": { "type": "string" },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "stale": { "type": "boolean" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "node_version": { "type": "integer", "minimum": 1 },
    "lifecycle_state": {
      "type": "string",
      "enum": ["active", "superseded", "demoted", "quarantined", "invalidated"]
    },
    "retrieval_weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_at": { "type": "string", "format": "date-time" },
    "invalid_at": { "type": "string", "format": "date-time" },
    "superseded_by": { "type": "string" },
    "contradicted_by": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "ref": { "type": "string" },
        "at": { "type": "string", "format": "date-time" }
      }
    },
    "invalidated_by": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "enum": ["git", "node", "human"] },
        "ref": { "type": "string" },
        "at": { "type": "string", "format": "date-time" }
      }
    },
    "demoted_at": { "type": "string", "format": "date-time" },
    "demotion_reason": {
      "type": "string",
      "enum": [
        "wrong_fact",
        "stale",
        "user_reject",
        "stale_trap",
        "injection_suspect",
        "git_drift"
      ]
    },
    "source_session": { "type": "string" },
    "corroboration_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
